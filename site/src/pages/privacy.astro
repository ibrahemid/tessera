---
import Base from "../layouts/Base.astro";
const repo = "https://github.com/ibrahemid/tessera";
const sections = [
  {
    h: "What Tessera stores",
    b: "Your two-factor accounts (issuer, label, and secret keys) are kept in an encrypted vault on your Mac. The vault is sealed with XChaCha20-Poly1305 under a random key, which is wrapped by a key derived from your passphrase with argon2id. On devices with a Secure Enclave, that key can also be protected by Touch ID.",
  },
  {
    h: "What Tessera transmits",
    b: "Nothing. Codes are generated entirely offline. Tessera connects to no server we operate and contains no analytics, advertising, or crash-reporting SDKs.",
  },
  {
    h: "Permissions",
    b: "Tessera runs in the macOS App Sandbox. On-screen QR scanning asks macOS for Screen Recording permission, used only to read a QR code at the moment you trigger a scan. Importing a file asks you to pick that file. Tessera requests nothing else.",
  },
  {
    h: "Data collection",
    b: "Tessera collects no data, as Apple's App Privacy guidelines define it. We cannot see your accounts or your codes. The Mac App Store privacy label reads “Data Not Collected.”",
  },
];
---
<Base title="Privacy · Tessera" description="Tessera collects nothing. Your 2FA secrets are encrypted on your device and never transmitted.">
  <article class="mx-auto w-full max-w-[var(--prose)] px-5 sm:px-7 py-16 sm:py-20">
    <span class="eyebrow">Privacy</span>
    <h1 class="mt-4" style="font-size: clamp(2rem, 5vw, 3rem)">Nothing to collect.</h1>
    <p class="mono text-xs mt-3" style="color: var(--ink-faint)">Last updated June 2026</p>

    <div class="tile p-6 sm:p-7 mt-9">
      <p class="leading-relaxed" style="color: var(--ink)">
        <strong>The short version:</strong> Tessera has no accounts, no servers we
        operate, and no analytics or tracking of any kind. Your data stays on your
        device, encrypted, and we have no way to see it.
      </p>
    </div>

    <div class="mt-10 space-y-9">
      {sections.map((s) => (
        <section>
          <h2 style="font-size: 1.25rem">{s.h}</h2>
          <p class="mt-2.5 leading-relaxed" style="color: var(--ink-soft)">{s.b}</p>
        </section>
      ))}

      <section>
        <h2 style="font-size: 1.25rem">Open source</h2>
        <p class="mt-2.5 leading-relaxed" style="color: var(--ink-soft)">
          Tessera is open source under Apache-2.0. You can read exactly what it does
          and build it yourself:
          <a class="font-medium" style="color: var(--gold)" href={repo} rel="noopener"> github.com/ibrahemid/tessera</a>.
        </p>
      </section>

      <section>
        <h2 style="font-size: 1.25rem">Contact</h2>
        <p class="mt-2.5 leading-relaxed" style="color: var(--ink-soft)">
          Questions about privacy:
          <a class="font-medium" style="color: var(--gold)" href="mailto:support@ibrahemid.com"> support@ibrahemid.com</a>.
        </p>
      </section>
    </div>
  </article>
</Base>
