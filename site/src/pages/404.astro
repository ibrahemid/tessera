---
import Base from "../layouts/Base.astro";
---
<Base title="Not found · Tessera" description="That page rolled over.">
  <section class="mx-auto w-full max-w-[var(--maxw)] px-5 sm:px-7 py-28 text-center">
    <div class="mono tnum mx-auto" style="font-size: clamp(3rem, 12vw, 7rem); letter-spacing: 0.04em; color: var(--ink)">4 0 4</div>
    <p class="mono text-sm mt-2" style="color: var(--gold)">code expired</p>
    <h1 class="mt-6" style="font-size: clamp(1.5rem, 4vw, 2.2rem)">That page rolled over.</h1>
    <p class="lede mt-4 max-w-md mx-auto">Like a one-time code, it isn't here anymore. Head back and grab a fresh one.</p>
    <a href="/" class="btn btn-gold mt-8">Back to Tessera</a>
  </section>
</Base>
