---
import "@fontsource-variable/schibsted-grotesk";
import "@fontsource-variable/hanken-grotesk";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/global.css";
import Wordmark from "../components/Wordmark.astro";

const {
  title = "Tessera · open-source 2FA for macOS",
  description = "A private, open-source two-factor authenticator for macOS. A native menu-bar app and a real command-line tool, sharing one encrypted vault. No account. No tracking. Free.",
} = Astro.props;
const year = 2026;
const repo = "https://github.com/ibrahemid/tessera";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#fbfaf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e0f13" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tessera.ibrahemid.com" />
    <meta property="og:image" content="https://tessera.ibrahemid.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://tessera.ibrahemid.com/og.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={new URL(Astro.url.pathname, "https://tessera.ibrahemid.com")} />
    <script is:inline>
      // Default to light on first visit (house rule: never default to dark);
      // only honor an explicit user choice saved by the toggle.
      (() => {
        try {
          if (localStorage.getItem("tessera-theme") === "dark") {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:px-4 focus:py-2 focus:rounded-lg focus:bg-surface focus:border focus:border-line"
      >Skip to content</a
    >

    <header
      class="sticky top-0 z-40 w-full border-b border-line"
      style="background: color-mix(in srgb, var(--paper) 82%, transparent); backdrop-filter: saturate(150%) blur(14px);"
    >
      <div class="mx-auto w-full max-w-[var(--maxw)] px-5 sm:px-7 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5" aria-label="Tessera home">
          <Wordmark />
        </a>
        <nav class="flex items-center gap-1 sm:gap-2 text-sm" style="color: var(--ink-soft)">
          <a href="/#features" class="hidden sm:inline px-3 py-2 rounded-lg hover:text-ink transition-colors">Features</a>
          <a href="/#trust" class="hidden sm:inline px-3 py-2 rounded-lg hover:text-ink transition-colors">Trust</a>
          <a href="/support" class="px-3 py-2 rounded-lg hover:text-ink transition-colors">Support</a>
          <a href={repo} class="px-3 py-2 rounded-lg hover:text-ink transition-colors" rel="noopener">Source</a>
          <button
            id="theme-toggle"
            type="button"
            class="ml-1 grid place-items-center w-9 h-9 rounded-lg border border-line hover:border-[var(--gold)] transition-colors"
            aria-label="Toggle color theme"
          >
            <svg class="theme-sun w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.4 1.4M17.6 17.6 19 19M5 19l1.4-1.4M17.6 6.4 19 5" />
            </svg>
            <svg class="theme-moon w-[18px] h-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="main" class="flex-1 w-full">
      <slot />
    </main>

    <footer class="border-t border-line mt-24">
      <div class="mx-auto w-full max-w-[var(--maxw)] px-5 sm:px-7 py-12">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8">
          <div class="max-w-sm">
            <Wordmark />
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--ink-soft)">
              Two-factor codes you actually own.
            </p>
          </div>
          <nav class="grid grid-cols-2 gap-x-12 gap-y-2 text-sm" style="color: var(--ink-soft)">
            <a href="/#get" class="py-1 hover:text-ink transition-colors">Get Tessera</a>
            <a href={repo} class="py-1 hover:text-ink transition-colors" rel="noopener">Source code</a>
            <a href="/support" class="py-1 hover:text-ink transition-colors">Support</a>
            <a href="/privacy" class="py-1 hover:text-ink transition-colors">Privacy</a>
            <a href="mailto:support@ibrahemid.com" class="py-1 hover:text-ink transition-colors">Contact</a>
            <a href={repo + "/blob/main/LICENSE"} class="py-1 hover:text-ink transition-colors" rel="noopener">License</a>
          </nav>
        </div>
        <div class="mt-10 pt-6 border-t border-line flex flex-wrap items-center justify-between gap-3 text-xs" style="color: var(--ink-faint)">
          <span>© {year} Tessera · Apache-2.0</span>
          <span>No accounts · No servers · No tracking</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const btn = document.getElementById("theme-toggle");
        const root = document.documentElement;
        const sun = btn?.querySelector(".theme-sun");
        const moon = btn?.querySelector(".theme-moon");
        const sync = () => {
          const dark = root.classList.contains("dark");
          sun?.classList.toggle("hidden", dark);
          moon?.classList.toggle("hidden", !dark);
        };
        sync();
        btn?.addEventListener("click", () => {
          const dark = root.classList.toggle("dark");
          try { localStorage.setItem("tessera-theme", dark ? "dark" : "light"); } catch (_) {}
          sync();
        });
      })();
    </script>
  </body>
</html>
