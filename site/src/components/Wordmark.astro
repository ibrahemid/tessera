---
const { size = 22 } = Astro.props;
---
<span class="flex items-center gap-2.5 font-semibold" style={`font-family: var(--font-display); font-size: ${size}px`}>
  <span class="glyph" style="width: 1.18em" aria-hidden="true">
    <span style="background: var(--gold-bright)"></span>
    <span style="background: color-mix(in srgb, var(--ink) 26%, var(--surface))"></span>
    <span style="background: color-mix(in srgb, var(--ink) 18%, var(--surface))"></span>
    <span style="background: color-mix(in srgb, var(--ink) 34%, var(--surface))"></span>
  </span>
  <span style="letter-spacing: -0.03em; color: var(--ink)">Tessera</span>
</span>
